# CanvasML Studio — Local Development Environment
# Copy to .env and modify as needed

# PostgreSQL
POSTGRES_DB=canvasml
POSTGRES_USER=canvasml
POSTGRES_PASSWORD=canvasml_dev_2024
DATABASE_URL=postgresql://canvasml:canvasml_dev_2024@localhost:5432/canvasml

# MinIO (S3-compatible)
MINIO_ROOT_USER=canvasml
MINIO_ROOT_PASSWORD=canvasml_dev_2024
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_ARTIFACTS=canvasml-artifacts
MINIO_BUCKET_UPLOADS=canvasml-uploads

# Redis
REDIS_URL=redis://localhost:6379/0

# Redpanda (Kafka-compatible)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
SCHEMA_REGISTRY_URL=http://localhost:18081

# OpenSearch
OPENSEARCH_URL=http://localhost:9200

# Gateway
GATEWAY_PORT=8000
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# LLM (Phase 4+)
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
